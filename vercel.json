{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js",
      "methods": ["GET", "POST","PUT","PATCH","DELETE","OPTIONS"]
    },
        {
      "src": "/api/ai-symptom-check",
      "dest": "/api/ai-symptom-check.js",
      "methods": ["GET", "POST","PUT","PATCH","DELETE","OPTIONS"]
    }
  ]
}

